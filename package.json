{
  "name": "ai-engineering",
  "version": "3.0.0-alpha.0",
  "description": "Multi-IDE AI agentic governance framework with subscription piggyback, federated plugins, and dual-plane security",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://ai-engineering.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/soydachi/ai-engineering.git"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "bun run --filter '*' typecheck",
    "clean": "rm -rf packages/*/dist packages/*/build coverage .ruff_cache .mypy_cache",
    "sync-mirrors": "bun packages/cli/src/main.ts sync-mirrors",
    "doctor": "bun packages/cli/src/main.ts doctor",
    "telemetry:tail": "tail -f .ai-engineering/state/framework-events.ndjson | jq ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "fast-check": "^3.23.2",
    "typescript": "^5.7.0"
  }
}
