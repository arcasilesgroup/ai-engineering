              "width": "fill_container",
              "layout": "vertical",
              "gap": 12,
              "children": [
                {
                  "type": "text",
                  "id": "Qn4aw",
                  "name": "s5sec1h",
                  "fill": "$text-primary",
                  "content": "The Problem",
                  "fontFamily": "Inter",
                  "fontSize": 24,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "5Kfy2",
                  "name": "s5sec1p",
                  "fill": "$text-muted",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "AI coding assistants are powerful but unpredictable. Without explicit governance, they skip tests, ignore security, introduce inconsistent patterns, and make decisions that nobody tracks. Teams lose control of quality as AI-written code scales.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
