{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arcasilesgroup.github.io/ai-engineering/schemas/manifest.schema.json",
  "title": "AI Engineering Manifest",
  "description": "Validates .ai-engineering/manifest.yml (parsed to JSON).",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "framework_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "providers": {
      "type": "object",
      "properties": {
        "vcs": {
          "type": "string",
          "enum": ["github", "azure_devops"]
        },
        "ides": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["claude_code", "github_copilot", "codex", "gemini", "cursor"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "stacks": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "python", "dotnet", "react", "typescript", "nextjs",
              "node", "nestjs", "react_native", "rust", "yaml",
              "terraform", "astro", "github_actions", "azure_pipelines",
              "azure", "bash", "powershell", "sql", "postgresql",
              "javascript", "java", "csharp", "go", "php",
              "ruby", "kotlin", "swift", "dart", "elixir"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["vcs", "ides", "stacks"],
      "additionalProperties": false
    },
    "artifact_feeds": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "work_items": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["github", "azure_devops"]
        },
        "azure_devops": {
          "type": "object",
          "properties": {
            "area_path": { "type": "string" },
            "iteration_path": { "type": "string" }
          },
          "additionalProperties": false
        },
        "github": {
          "type": "object",
          "properties": {
            "team_label": { "type": "string" },
            "project": { "type": ["string", "integer"] }
          },
          "additionalProperties": false
        },
        "state_mapping": {
          "type": "object",
          "properties": {
            "refinement": { "type": ["string", "null"] },
            "ready": { "type": ["string", "null"] },
            "in_progress": { "type": ["string", "null"] },
            "in_review": { "type": ["string", "null"] },
            "done": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "process_template": {
          "type": ["string", "null"],
          "enum": ["basic", "agile", "scrum", "cmmi", null]
        },
        "custom_fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "number", "date", "single_select", "iteration"] }
            },
            "required": ["id", "name", "type"],
            "additionalProperties": false
          }
        },
        "github_project": {
          "type": "object",
          "properties": {
            "number": { "type": ["integer", "null"] },
            "status_field_id": { "type": ["string", "null"] },
            "status_options": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "hierarchy": {
          "type": "object",
          "properties": {
            "feature": {
              "type": "string",
              "enum": ["never_close", "close_on_pr", "close_on_merge"]
            },
            "user_story": {
              "type": "string",
              "enum": ["never_close", "close_on_pr", "close_on_merge"]
            },
            "task": {
              "type": "string",
              "enum": ["never_close", "close_on_pr", "close_on_merge"]
            },
            "bug": {
              "type": "string",
              "enum": ["never_close", "close_on_pr", "close_on_merge"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "quality": {
      "type": "object",
      "properties": {
        "coverage": { "type": "integer", "minimum": 0, "maximum": 100 },
        "duplication": { "type": "integer", "minimum": 0, "maximum": 100 },
        "cyclomatic": { "type": "integer", "minimum": 1 },
        "cognitive": { "type": "integer", "minimum": 1 }
      },
      "required": ["coverage", "duplication", "cyclomatic", "cognitive"],
      "additionalProperties": false
    },
    "documentation": {
      "type": "object",
      "properties": {
        "auto_update": {
          "type": "object",
          "properties": {
            "readme": { "type": "boolean" },
            "changelog": { "type": "boolean" },
            "solution_intent": { "type": "boolean" }
          },
          "required": ["readme", "changelog", "solution_intent"],
          "additionalProperties": false
        },
        "external_portal": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "source": { "type": ["string", "null"] },
            "update_method": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "required": ["auto_update"],
      "additionalProperties": false
    },
    "cicd": {
      "type": "object",
      "properties": {
        "standards_url": { "type": ["string", "null"] }
      },
      "required": ["standards_url"],
      "additionalProperties": false
    },
    "contexts": {
      "type": "object",
      "properties": {
        "precedence": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["team", "frameworks", "languages"]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["precedence"],
      "additionalProperties": false
    },
    "skills": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "prefix": { "type": "string", "pattern": "^ai-$" },
        "registry": {
          "type": "object",
          "patternProperties": {
            "^ai-[a-z][a-z0-9-]*$": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["workflow", "delivery", "enterprise", "teaching", "writing", "sdlc", "meta"]
                },
                "tags": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1,
                  "uniqueItems": true
                }
              },
              "required": ["type", "tags"],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["total", "prefix", "registry"],
      "additionalProperties": false
    },
    "agents": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "names": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "required": ["total", "names"],
      "additionalProperties": false
    },
    "ownership": {
      "type": "object",
      "properties": {
        "framework": {
          "type": "array",
          "items": { "type": "string" }
        },
        "team": {
          "type": "array",
          "items": { "type": "string" }
        },
        "system": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["framework", "team", "system"],
      "additionalProperties": false
    },
    "tooling": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "telemetry": {
      "type": "object",
      "properties": {
        "consent": {
          "type": "string",
          "enum": ["strict-opt-in", "opt-in", "opt-out"]
        },
        "default": {
          "type": "string",
          "enum": ["enabled", "disabled"]
        }
      },
      "required": ["consent", "default"],
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "framework_version",
    "name",
    "version",
    "providers",
    "quality",
    "documentation",
    "cicd",
    "skills",
    "agents",
    "ownership",
    "tooling",
    "telemetry"
  ],
  "additionalProperties": false
}
