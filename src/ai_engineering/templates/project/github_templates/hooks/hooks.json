{
  "hooks": [
    {
      "type": "post_tool_call",
      "script": ".ai-engineering/scripts/hooks/telemetry-skill.sh",
      "description": "Emit skill_invoked telemetry after tool use"
    },
    {
      "type": "session_end",
      "script": ".ai-engineering/scripts/hooks/telemetry-session.sh end",
      "description": "Emit session_end telemetry when session closes"
    },
    {
      "type": "post_tool_call",
      "script": ".ai-engineering/scripts/hooks/telemetry-agent.sh",
      "description": "Emit agent_dispatched telemetry after agent use"
    }
  ]
}
