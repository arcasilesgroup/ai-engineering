{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./.ai-engineering/scripts/hooks/copilot-session-start.sh",
        "powershell": "./.ai-engineering/scripts/hooks/copilot-session-start.ps1",
        "timeoutSec": 10,
        "comment": "Emit session_start telemetry on session initialization"
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./.ai-engineering/scripts/hooks/copilot-session-end.sh",
        "powershell": "./.ai-engineering/scripts/hooks/copilot-session-end.ps1",
        "timeoutSec": 10,
        "comment": "Emit session_end telemetry when session closes"
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./.ai-engineering/scripts/hooks/copilot-skill.sh",
        "powershell": "./.ai-engineering/scripts/hooks/copilot-skill.ps1",
        "timeoutSec": 10,
        "comment": "Emit skill_invoked telemetry on /ai-* commands"
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "./.ai-engineering/scripts/hooks/copilot-deny.sh",
        "powershell": "./.ai-engineering/scripts/hooks/copilot-deny.ps1",
        "timeoutSec": 5,
        "comment": "Enforce deny-list: block dangerous operations (rm -rf, force push, --no-verify)"
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./.ai-engineering/scripts/hooks/copilot-agent.sh",
        "powershell": "./.ai-engineering/scripts/hooks/copilot-agent.ps1",
        "timeoutSec": 10,
        "comment": "Emit agent_dispatched telemetry on agent tool use"
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "./.ai-engineering/scripts/hooks/copilot-error.sh",
        "powershell": "./.ai-engineering/scripts/hooks/copilot-error.ps1",
        "timeoutSec": 10,
        "comment": "Emit error_occurred telemetry on failures"
      }
    ]
  }
}
