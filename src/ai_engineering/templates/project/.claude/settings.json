{
  "permissions": {
    "allow": [
      "Bash(ruff *)",
      "Bash(ty *)",
      "Bash(uv *)",
      "Bash(pip-audit *)",
      "Bash(gitleaks *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(pytest *)",
      "Bash(.venv/bin/ruff *)",
      "Bash(.venv/Scripts/ruff *)",
      "Bash(.venv/bin/ty *)",
      "Bash(.venv/Scripts/ty *)",
      "Bash(.venv/bin/python -m pytest *)",
      "Bash(.venv/Scripts/python -m pytest *)",
      "Bash(.venv/bin/pip-audit *)",
      "Bash(.venv/Scripts/pip-audit *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- . *)",
      "Bash(git checkout . *)",
      "Bash(git restore . *)",
      "Bash(git clean -f *)",
      "Bash(git commit*--no-verify*)",
      "Bash(git push*--no-verify*)",
      "Bash(git merge*--no-verify*)",
      "Bash(git rebase*--no-verify*)",
      "Bash(*--no-verify*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "/ai-",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/telemetry-skill.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/prompt-injection-guard.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/strategic-compact.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/mcp-health.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/observe.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/observe.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/auto-format.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "mcp__",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/mcp-health.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/cost-tracker.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/instinct-extract.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
