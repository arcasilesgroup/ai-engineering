{
  "permissions": {
    "allow": [
      "Bash(ruff *)",
      "Bash(ty *)",
      "Bash(uv *)",
      "Bash(pip-audit *)",
      "Bash(gitleaks *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(pytest *)",
      "Bash(.venv/bin/ruff *)",
      "Bash(.venv/Scripts/ruff *)",
      "Bash(.venv/bin/ty *)",
      "Bash(.venv/Scripts/ty *)",
      "Bash(.venv/bin/python -m pytest *)",
      "Bash(.venv/Scripts/python -m pytest *)",
      "Bash(.venv/bin/pip-audit *)",
      "Bash(.venv/Scripts/pip-audit *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- . *)",
      "Bash(git checkout . *)",
      "Bash(git restore . *)",
      "Bash(git clean -f *)",
      "Bash(git commit*--no-verify*)",
      "Bash(git push*--no-verify*)",
      "Bash(git merge*--no-verify*)",
      "Bash(git rebase*--no-verify*)",
      "Bash(*--no-verify*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/telemetry-skill.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/telemetry-agent.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/telemetry-session.sh\" end",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
