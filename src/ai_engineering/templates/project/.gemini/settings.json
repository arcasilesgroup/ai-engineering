{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Bash",
      "Agent",
      "Glob",
      "Grep",
      "Skill",
      "TaskCreate",
      "TaskUpdate",
      "mcp__context7__*",
      "mcp__notebooklm-mcp__*"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- . *)",
      "Bash(git checkout . *)",
      "Bash(git restore . *)",
      "Bash(git clean -f *)",
      "Bash(git commit*--no-verify*)",
      "Bash(git push*--no-verify*)",
      "Bash(git merge*--no-verify*)",
      "Bash(git rebase*--no-verify*)",
      "Bash(*--no-verify*)"
    ]
  },
  "hooksConfig": {
    "enabled": true
  },
  "hooks": {
    "BeforeAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "name": "telemetry-skill",
            "command": "AIENG_HOOK_ENGINE=gemini python3 \"$GEMINI_PROJECT_DIR/.ai-engineering/scripts/hooks/telemetry-skill.py\"",
            "timeout": 10000,
            "description": "Log skill invocation telemetry"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "name": "prompt-injection-guard",
            "command": "AIENG_HOOK_ENGINE=gemini python3 \"$GEMINI_PROJECT_DIR/.ai-engineering/scripts/hooks/prompt-injection-guard.py\"",
            "timeout": 15000,
            "description": "Scan tool input for prompt injection"
          }
        ]
      },
      {
        "matcher": "edit_file|write_file|replace",
        "hooks": [
          {
            "type": "command",
            "name": "strategic-compact",
            "command": "AIENG_HOOK_ENGINE=gemini python3 \"$GEMINI_PROJECT_DIR/.ai-engineering/scripts/hooks/strategic-compact.py\"",
            "timeout": 5000,
            "description": "Optimize context for large files"
          }
        ]
      },
      {
        "matcher": "mcp_.*",
        "hooks": [
          {
            "type": "command",
            "name": "mcp-health",
            "command": "AIENG_HOOK_ENGINE=gemini python3 \"$GEMINI_PROJECT_DIR/.ai-engineering/scripts/hooks/mcp-health.py\"",
            "timeout": 15000,
            "description": "Check health of MCP servers"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "name": "instinct-observe-pre",
            "command": "AIENG_HOOK_ENGINE=gemini python3 \"$GEMINI_PROJECT_DIR/.ai-engineering/scripts/hooks/instinct-observe.py\"",
            "timeout": 10000,
            "description": "Record pre-tool state for instincts"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "name": "instinct-observe-post",
            "command": "AIENG_HOOK_ENGINE=gemini python3 \"$GEMINI_PROJECT_DIR/.ai-engineering/scripts/hooks/instinct-observe.py\"",
            "timeout": 10000,
            "description": "Record post-tool state for instincts"
          }
        ]
      },
      {
        "matcher": "Agent|dispatch_agent",
        "hooks": [
          {
            "type": "command",
            "name": "observe-agent",
            "command": "AIENG_HOOK_ENGINE=gemini python3 \"$GEMINI_PROJECT_DIR/.ai-engineering/scripts/hooks/observe.py\"",
            "timeout": 10000,
            "description": "Log agent dispatch telemetry"
          }
        ]
      },
      {
        "matcher": "edit_file|write_file|replace|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "name": "auto-format",
            "command": "AIENG_HOOK_ENGINE=gemini python3 \"$GEMINI_PROJECT_DIR/.ai-engineering/scripts/hooks/auto-format.py\"",
            "timeout": 15000,
            "description": "Auto-format edited files"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "name": "instinct-extract",
            "command": "AIENG_HOOK_ENGINE=gemini python3 \"$GEMINI_PROJECT_DIR/.ai-engineering/scripts/hooks/instinct-extract.py\"",
            "timeout": 30000,
            "description": "Extract learned instincts from session"
          }
        ]
      }
    ]
  }
}
